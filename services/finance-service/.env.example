# ============================================
# PROJECT FINANCE - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/Finance?schema=public"

# For Docker/Production:
# DATABASE_URL="postgresql://postgres:your_password@postgres:5432/Finance?schema=public"

# ============================================
# JWT/SECURITY CONFIGURATION
# ============================================
JWT_SECRET="your-super-secret-jwt-key-min-32-characters-long"
# Generate with: openssl rand -base64 32

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development
# Options: development, production, test

SERVICE_NAME="Project Finance API"

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGIN=http://localhost:5173
# For production, set to your frontend domain:
# CORS_ORIGIN=https://your-domain.com

# ============================================
# EMAIL CONFIGURATION (SMTP)
# ============================================

# For Gmail:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=noreply@projectfinance.com

# To get Gmail App Password:
# 1. Go to Google Account Settings
# 2. Security > 2-Step Verification
# 3. App Passwords > Generate new
# 4. Use generated password here

# For Other Email Providers:
# Outlook/Office365:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587

# Yahoo:
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587

# SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# ============================================
# BANK API CONFIGURATION (For Production)
# ============================================
# Currently using simulation mode
# Uncomment and configure when integrating with real bank API

# BANK_API_URL=https://api.bank.com
# BANK_API_KEY=your-bank-api-key
# BANK_API_SECRET=your-bank-api-secret

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
MAX_FILE_SIZE=10485760
# 10MB in bytes (10 * 1024 * 1024)

UPLOAD_PATH=./uploads
# For production, use absolute path or cloud storage

# ============================================
# CLOUD STORAGE (Optional - for production)
# ============================================
# AWS S3:
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_S3_BUCKET=your-bucket-name
# AWS_REGION=ap-southeast-1

# Google Cloud Storage:
# GCS_PROJECT_ID=your-project-id
# GCS_BUCKET=your-bucket-name
# GCS_KEY_FILE=path/to/keyfile.json

# ============================================
# LOGGING & MONITORING (Optional)
# ============================================
# LOG_LEVEL=info
# Options: error, warn, info, debug, trace

# Sentry (Error Tracking):
# SENTRY_DSN=https://your-sentry-dsn

# ============================================
# RATE LIMITING (Production)
# ============================================
# RATE_LIMIT_WINDOW_MS=900000
# 15 minutes in milliseconds

# RATE_LIMIT_MAX_REQUESTS=100
# Max requests per window

# ============================================
# SESSION CONFIGURATION
# ============================================
# SESSION_SECRET=your-session-secret
# SESSION_COOKIE_MAX_AGE=86400000
# 24 hours in milliseconds

# ============================================
# CACHE CONFIGURATION (Optional - Redis)
# ============================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0

# ============================================
# NOTIFICATION SETTINGS
# ============================================
# ENABLE_EMAIL_NOTIFICATIONS=true
# ENABLE_SMS_NOTIFICATIONS=false

# ============================================
# BACKUP CONFIGURATION
# ============================================
# BACKUP_ENABLED=true
# BACKUP_SCHEDULE="0 2 * * *"
# Daily at 2 AM

# BACKUP_PATH=/path/to/backups
# BACKUP_RETENTION_DAYS=30

# ============================================
# FEATURE FLAGS
# ============================================
# ENABLE_BANK_INTEGRATION=false
# ENABLE_PAYMENT_GATEWAY=false
# ENABLE_ANALYTICS=true
# ENABLE_TWO_FACTOR_AUTH=false

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
# SKIP_EMAIL_SENDING=true
# USE_MOCK_DATA=false
# DEBUG_MODE=false

# ============================================
# NOTES
# ============================================
# 1. Never commit .env file to version control
# 2. Keep .env.example updated with new variables
# 3. Use strong passwords and secrets in production
# 4. Rotate secrets regularly
# 5. Use environment-specific .env files:
#    - .env.development
#    - .env.production
#    - .env.test
